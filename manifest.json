{
  "manifest_version": 3,
  "name": "CupColors",
  "version": "1.0.0",
  "description": "Click a year and your live World Cup stream gets that tournament's color. Works on RTVE, DAZN and any HTML5 player.",
  "permissions": ["scripting", "activeTab", "storage"],
  "host_permissions": ["<all_urls>"],
  "browser_specific_settings": {
    "gecko": {
      "id": "cupcolors@lucachu.dev",
      "strict_min_version": "115.0"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "CupColors",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
